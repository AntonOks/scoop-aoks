{
    "homepage": "https://invent.kde.org/sdk/kdiff3",
    "description": "Utility for comparing and merging files and directories",
    "version": "1.8.3",
    "license": "GPL-2.0-only",
    "architecture": {
        "64bit": {
            "url": "https://download.kde.org/stable/kdiff3/kdiff3-1.8.3-windows-64.exe"
        }
    },
    "bin": "kdiff3.exe",
    "shortcuts": [
        [
            "kdiff3.exe",
            "KDiff3"
        ]
    ],
    "checkver": {
        "url": "https://invent.kde.org/sdk/kdiff3/-/raw/master/ChangeLog",
        "re": "Version ([\\d.]+) - "
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.kde.org/stable/kdiff3/kdiff3-$version-windows-64.exe"
            }
        }
    }
}
